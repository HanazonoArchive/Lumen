{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lumen",
  "version": "0.1.0",
  "identifier": "com.hanazono.lumen",
  "build": {
    "frontendDist": "../src",
    "beforeDevCommand": "",
    "beforeBuildCommand": "powershell -ExecutionPolicy Bypass -File \"../download-7z.ps1\""
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/icon.ico"
    ],
    "resources": {
      "../resources/7z.exe": "resources/7z.exe",
      "../resources/7z.dll": "resources/7z.dll"
    },
    "windows": {
      "wix": null
    }
  },
  "app": {
    "windows": [
      {
        "title": "Lumen",
        "width": 1050,
        "height": 680,
        "minWidth": 800,
        "minHeight": 500,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
